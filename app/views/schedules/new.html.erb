<div style="background: #f5f0e8; min-height: 100vh; padding: 40px 20px;">
  <div style="max-width: 600px; margin: 0 auto;">
    <h1 style="font-size: 32px; font-weight: 700; color: #2d2d2d; margin-bottom: 30px;">Create New Schedule</h1>

    <%= form_with model: @schedule, local: true do |f| %>
      <% if @schedule.errors.any? %>
        <div style="background: #ffebee; color: #c62828; padding: 16px; border-radius: 8px; margin-bottom: 20px;">
          <h3 style="margin: 0 0 8px 0;"><%= pluralize(@schedule.errors.count, "error") %> prevented this schedule from being saved:</h3>
          <ul style="margin: 0; padding-left: 20px;">
            <% @schedule.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div style="margin-bottom: 24px;">
        <%= f.label :name, "Schedule Name (Optional)", style: "display: block; font-weight: 600; color: #2d2d2d; margin-bottom: 8px;" %>
        <%= f.text_field :name, placeholder: "e.g., Work Day, Study Session", style: "width: 100%; padding: 12px; border: 1px solid #e0e0e0; border-radius: 6px; font-size: 14px;" %>
        <p style="color: #999; font-size: 12px; margin: 4px 0 0 0;">Give your schedule a custom name. If left blank, the day of the week will be used.</p>
      </div>

      <div style="margin-bottom: 24px;">
        <%= f.label :date, "Date", style: "display: block; font-weight: 600; color: #2d2d2d; margin-bottom: 8px;" %>
        <%= f.date_field :date, style: "width: 100%; padding: 12px; border: 1px solid #e0e0e0; border-radius: 6px; font-size: 14px;" %>
      </div>

      <div style="display: flex; gap: 12px;">
        <%= f.submit "Create Schedule", style: "background: #d97c3a; color: white; padding: 12px 24px; border: none; border-radius: 6px; font-weight: 600; cursor: pointer; font-size: 14px;" %>
        <%= link_to "Cancel", schedules_path, style: "background: white; color: #d97c3a; padding: 12px 24px; border: 2px solid #d97c3a; border-radius: 6px; font-weight: 600; text-decoration: none; font-size: 14px;" %>
      </div>
    <% end %>
  </div>
</div>
