<% # app/views/schedules/show.html.erb %>


<%= button_to "Create task with ai ✨",
    create_with_ai_schedule_tasks_path(@schedule),
    method: :post,
    class: "btn-optimize",
    data: {
      turbo_confirm: "Add an AI-generated task to your schedule?",
      disable_with: "Creating..."
    } %>

<div class="schedule-container">
  <% if alert %>
  <div style="
    background-color: #FFF3CD;
    border: 1px solid #C1713A;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    margin-bottom: 1rem;
    font-size: 0.85rem;
    color: #7A6E63;
    font-family: 'Arial', sans-serif;">
    ⚠️ <%= alert %>
  </div>
  <% end %>

  <!-- Header -->
  <div class="schedule-header">
    <div>
      <p class="schedule-label">DAILY SCHEDULE</p>
      <h1 class="schedule-title"><%= @schedule.name.presence || @schedule.date.strftime('%A') %></h1>
      <p style="color: #999; font-size: 14px; margin: 4px 0 0 0;"><%= @schedule.date.strftime('%A, %B %d') %></p>
    </div>

    <div class="header-buttons">
      <button class="btn-optimize" data-bs-toggle="modal" data-bs-target="#exampleModal">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2v20M2 12h20"></path>
        </svg>
        Optimize My Schedule
      </button>
      <button class="btn-add-task" data-bs-toggle="modal" data-bs-target="#addTaskModal">
        + Add Task
      </button>
    </div>
  </div>

  <!-- Tasks Timeline -->
  <div class="tasks-timeline">
  <% if @tasks.empty? %>
    <div class="empty-state">
      <p>No tasks yet. Add one to get started!</p>
    </div>
  <% else %>
    <div style="display: flex; gap: 0;">

      <!-- Time markers column -->
      <div style="width: 64px; flex-shrink: 0; padding-top: 2px;">
        <% @tasks.each do |task| %>
          <div style="height: 90px; display: flex; align-items: flex-start;">
            <span style="font-size: 12px; color: #9c8c7a; font-weight: 500;">
              <%= task.display_time&.strftime('%H:%M') %>
            </span>
          </div>
        <% end %>
      </div>

      <!-- Timeline line + cards -->
      <div style="position: relative; padding-left: 20px; flex: 1;">

        <!-- Gradient line -->
        <div style="
          position: absolute;
          left: 0;
          top: 8px;
          bottom: 8px;
          width: 2px;
          background: linear-gradient(
            to bottom,
            #FFD966,
            #F4A940,
            #D97C3A,
            #C1613A,
            #8B3A2A
          );
        "></div>

        <% @tasks.each_with_index do |task, index| %>
          <%
            total    = @tasks.length
            progress = total > 1 ? index.to_f / (total - 1) : 0
            dot_color = interpolate_day_color(progress)
          %>

          <div style="margin-bottom: 16px; position: relative;">
            <!-- Gradient dot -->
            <div style="
              position: absolute;
              left: -27px;
              top: 12px;
              width: 13px;
              height: 13px;
              border-radius: 50%;
              background: <%= dot_color %>;
              border: 2px solid #f5f0e8;
            "></div>

            <!-- Task card -->
            <div class="task-card <%= 'completed' if task.completed? %>">
              <div class="task-meta">
                <span class="task-time"><%= task.display_time&.strftime('%I:%M %p') %></span>
                <span class="task-duration"><%= task.duration_min %> mins</span>
                <span class="task-badge <%= task.time_type %>"><%= task.time_badge %></span>
              </div>
              <h3 class="task-title"><%= task.category %></h3>
              <div class="task-actions">
                <a href="#"
                  class="action-link"
                  data-bs-toggle="modal"
                  data-bs-target="#editTaskModal"
                  data-task-id="<%= task.id %>"
                  data-schedule-id="<%= @schedule.id %>"
                  data-task-title="<%= task.category %>"
                  data-task-time="<%= task.display_time&.strftime('%H:%M') %>"
                  data-task-duration="<%= task.duration_min %>"
                  data-task-type="<%= task.time_type %>"
                  onclick="populateEditModal(event)">Edit</a>
                <%= button_to 'Delete', schedule_task_path(@schedule, task),
                    method: :delete,
                    data: { turbo_confirm: 'Remove task?' },
                    class: 'action-link delete',
                    form_class: 'inline-delete-form' %>
                <%= form_with url: schedule_task_path(@schedule, task), method: :patch, data: { turbo: false }, style: "display:inline" do %>
                  <input type="hidden" name="task[completed]" value="<%= task.completed ? 'false' : 'true' %>">
                  <input type="checkbox" class="task-toggle" id="toggle-<%= task.id %>" <%= task.completed ? 'checked' : '' %> onchange="this.form.submit()">
                  <label for="toggle-<%= task.id %>"></label>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

    </div>
  <% end %>
</div>

  <!-- Chat Button -->
  <div style="text-align: center; margin: 50px 0;">
    <button type="button" class="btn-chat-aevi" data-bs-toggle="modal" data-bs-target="#exampleModal">
      💬 Chat to Aevi
    </button>
  </div>

  <!-- Back Link -->
  <div class="footer-actions">
    <%= link_to '← Back to Schedules', schedules_path, class: 'back-link' %>
  </div>

</div>

<!-- Modals -->
<%= render 'add_task_modal', schedule: @schedule %>
<%= render 'edit_task_modal', schedule: @schedule %>

<!-- Chat Modal -->
<div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h1 class="modal-title fs-5" id="exampleModalLabel">Lets optimise your day together! chat with Aevi for inspiration</h1>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <% user_message_count = @schedule.messages.where(role: "user").count %>
        <% if user_message_count >= 20 %>
          <div style="background-color: #FFF3CD; border: 1px solid #C1713A; border-radius: 8px; padding: 0.75rem 1rem; margin-bottom: 1rem; font-size: 0.85rem; color: #7A6E63;">
            You've reached the 20 message limit for this schedule. Start a new schedule to keep chatting with Aevi.
          </div>
        <% end %>
        <div id="messages" style="max-height: 350px; overflow-y: auto; margin-bottom: 1rem;">
          <%= render @schedule.messages %>
        </div>
        <% unless user_message_count >= 20 %>
          <div id="message_form">
            <%= render "messages/form", schedule: @schedule, message: @message %>
          </div>
        <% end %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>


<script>
  document.addEventListener("turbo:after-stream-render", () => {
    const messages = document.getElementById("messages");
    if (messages) messages.scrollTop = messages.scrollHeight;
  });
</script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const aiForm = document.querySelector('form[action*="create_with_ai"]');
    if (!aiForm) return;

    const aiButton = aiForm.querySelector('button, input[type="submit"]');
    if (!aiButton) return;

    aiForm.addEventListener('submit', function() {
      aiButton.disabled = true;
      aiButton.value    = 'Creating...';
      aiButton.innerText = 'Creating...';
      setTimeout(() => {
        aiButton.disabled  = false;
        aiButton.value     = 'Create task with ai ✨';
        aiButton.innerText = 'Create task with ai ✨';
      }, 8000);
    });
  });
</script>
