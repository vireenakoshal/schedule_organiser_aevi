<style>
  body {
    background-color: #F5F0E8;
    font-family: 'Georgia', serif;
  }

  .page-wrapper {
    max-width: 480px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .label-small {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #C1713A;
    font-family: 'Arial', sans-serif;
  }

  .schedule-date {
    font-size: 2.4rem;
    font-weight: 700;
    color: #1C1C1C;
    line-height: 1.1;
    margin: 0.25rem 0 2rem 0;
  }

  .timeline {
    position: relative;
    padding-left: 1rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 1px;
    background-color: #D9CFC2;
  }

  .timeline-item {
    position: relative;
    margin-bottom: 1.5rem;
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: -1.35rem;
    top: 0.35rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #C1713A;
  }

  .task-time {
    font-size: 0.75rem;
    color: #9C8C7A;
    font-family: 'Arial', sans-serif;
    margin-bottom: 0.4rem;
    letter-spacing: 0.05em;
  }

  .task-card {
    background-color: #FFFFFF;
    border-radius: 12px;
    padding: 1rem 1.2rem;
    border: none;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }

  .task-card h5 {
    font-size: 1.05rem;
    font-weight: 600;
    color: #1C1C1C;
    margin-bottom: 0.25rem;
  }

  .task-card p {
    font-size: 0.85rem;
    color: #7A6E63;
    margin-bottom: 0;
  }

  .badge-fixed {
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background-color: #C1713A;
    color: white;
    padding: 0.25rem 0.6rem;
    border-radius: 20px;
    font-family: 'Arial', sans-serif;
  }

  .badge-preferred {
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background-color: #E8DDD0;
    color: #C1713A;
    padding: 0.25rem 0.6rem;
    border-radius: 20px;
    font-family: 'Arial', sans-serif;
  }

  .task-actions a {
    font-size: 0.75rem;
    color: #9C8C7A;
    text-decoration: none;
    margin-left: 0.75rem;
  }

  .task-actions a:hover {
    color: #C1713A;
  }

  .btn-add-task {
    background-color: #C1713A;
    color: white;
    border: none;
    border-radius: 8px;
    padding: 0.5rem 1.2rem;
    font-size: 0.85rem;
    font-family: 'Arial', sans-serif;
    text-decoration: none;
  }

  .btn-add-task:hover {
    background-color: #A85E2E;
    color: white;
  }

  .btn-back {
    font-size: 0.8rem;
    color: #9C8C7A;
    text-decoration: none;
    font-family: 'Arial', sans-serif;
  }

  .btn-back:hover {
    color: #C1713A;
  }

  .empty-state {
    font-size: 0.9rem;
    color: #9C8C7A;
    font-family: 'Arial', sans-serif;
    padding: 1rem 0;
  }
</style>

<div class="page-wrapper">

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-1">
    <span class="label-small">Daily Schedule</span>
    <%= link_to "+ Add Task", new_schedule_task_path(@schedule), class: "btn-add-task" %>
  </div>

  <!-- Date -->
  <h1 class="schedule-date"><%= @schedule.date.strftime("%A, %b %-d") %></h1>

  <!-- Task Timeline -->
  <% if @tasks.empty? %>
    <p class="empty-state">No tasks yet — add one above.</p>
  <% else %>
    <div class="timeline">
      <% @tasks.each do |task| %>
        <div class="timeline-item">

          <!-- Time -->
          <div class="d-flex justify-content-between align-items-center mb-1">
            <p class="task-time mb-0">
              <% if task.fixed_time.present? %>
                <%= task.fixed_time.strftime("%I:%M %p") %>
              <% elsif task.preferred_time.present? %>
                <%= task.preferred_time.strftime("%I:%M %p") %>
              <% else %>
                Flexible
              <% end %>
              &nbsp;·&nbsp; <%= task.duration_min %> mins
            </p>
            <% if task.fixed_time.present? %>
              <span class="badge-fixed">Fixed</span>
            <% elsif task.preferred_time.present? %>
              <span class="badge-preferred">Preferred</span>
            <% end %>
          </div>

          <!-- Card -->
          <div class="task-card">
            <div class="d-flex justify-content-between align-items-start">
              <h5><%= task.category %></h5>
              <div class="task-actions">
                <%= link_to "Edit", edit_schedule_task_path(@schedule, task) %>
                <%= link_to "Delete", schedule_task_path(@schedule, task), method: :delete, data: { confirm: "Delete this task?" } %>
              </div>
            </div>
          </div>

        </div>
      <% end %>
    </div>
  <% end %>

 <!-- Button trigger modal -->
  <button type="button" class="btn btn-primary mt-3" data-bs-toggle="modal" data-bs-target="#exampleModal">
    CHAT TO AEVI - OPTIMISE YOUR DAY
  </button>

  <!-- Modal -->
  <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">

        <div class="modal-header">
          <h1 class="modal-title fs-5" id="exampleModalLabel">Lets optimise your day together! chat with Aevi for inspiration</h1>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <div class="modal-body">
          <% user_message_count = @schedule.messages.where(role: "user").count %>

          <% if user_message_count >= 20 %>
            <div style="
              background-color: #FFF3CD;
              border: 1px solid #C1713A;
              border-radius: 8px;
              padding: 0.75rem 1rem;
              margin-bottom: 1rem;
              font-size: 0.85rem;
              color: #7A6E63;
              font-family: 'Arial', sans-serif;">
              You've reached the 20 message limit for this schedule. Start a new schedule to keep chatting with Aevi.
            </div>
          <% end %>

          <div id="messages" style="max-height: 350px; overflow-y: auto; margin-bottom: 1rem;">
            <%= render @schedule.messages %>
          </div>

          <% unless user_message_count >= 10 %>
          <div id="message_form">
            <%= render "messages/form", schedule: @schedule, message: @message %>
          </div>
          <% end %>
        </div>

        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        </div>

      </div>
    </div>
  </div>

  <!-- Footer -->
  <div class="mt-4">
    <%= link_to "← Back to Schedules", schedules_path, class: "btn-back" %>
  </div>

</div>

<script>
  document.addEventListener("turbo:after-stream-render", () => {
    const messages = document.getElementById("messages");
    if (messages) messages.scrollTop = messages.scrollHeight;
  });
</script>
