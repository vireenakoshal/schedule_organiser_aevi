<footer style="
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #d97c3a;
  display: flex;
  z-index: 1000;
  border-top: 1px solid #c26b2e;
">
  <%= link_to schedules_path,
      style: "flex: 1; display: flex; align-items: center; justify-content: center; gap: 8px; padding: 16px; color: white; text-decoration: none; font-size: 14px; font-weight: 600; border-right: 1px solid #c26b2e;" do %>
    📊 Your Schedules
  <% end %>

  <%= link_to new_schedule_path,
      style: "flex: 1; display: flex; align-items: center; justify-content: center; gap: 8px; padding: 16px; color: white; text-decoration: none; font-size: 14px; font-weight: 600;" do %>
    📅 Add Schedule
  <% end %>
</footer>
