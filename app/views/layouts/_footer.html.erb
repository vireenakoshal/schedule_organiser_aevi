<footer class="mt-5" style="background: linear-gradient(135deg, #F5F1ED 0%, #FFF9F5 100%); border-top: 2px solid #D97E3B; padding: 16px 20px;">
  <div class="container-fluid">
    <div class="row g-2">
      <div class="col-6 col-md-6">
        <%= link_to schedules_path, class: "btn w-100", style: "background-color: #D97E3B; color: white; font-weight: 600; padding: 12px;" do %>
          ← Back to Schedule
        <% end %>
      </div>
      <div class="col-6 col-md-6">
        <%= link_to new_schedule_path, class: "btn w-100", style: "background-color: #D97E3B; color: white; font-weight: 600; padding: 12px;" do %>
          📅 Add Schedule
        <% end %>
      </div>
    </div>
  </div>
</footer>
