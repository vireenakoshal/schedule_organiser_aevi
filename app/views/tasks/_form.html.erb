x<div class="task-form-container">
  <%= form_with model: [@schedule, @task], local: true do |f| %>
    <% if @task.errors.any? %>
      <div class="error-messages">
        <h3><%= pluralize(@task.errors.count, "error") %> prevented this task from being saved:</h3>
        <ul>
          <% @task.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= f.label :category, "Task Title" %>
      <%= f.text_field :category, placeholder: "e.g., Project Strategy Review", class: "form-input" %>
    </div>

    <div class="form-group">
      <%= f.label :duration_min, "Duration (minutes)" %>
      <%= f.number_field :duration_min, placeholder: "60", class: "form-input" %>
    </div>

    <div class="time-type-section">
      <p class="time-type-label">Time Type</p>

      <div class="time-option">
        <%= f.label :fixed_time, "Fixed Time" %>
        <%= f.time_field :fixed_time, class: "form-input" %>
      </div>

      <div class="time-option">
        <%= f.label :preferred_time, "Preferred Time (Flexible)" %>
        <%= f.time_field :preferred_time, class: "form-input" %>
      </div>
    </div>

    <div class="form-actions">
      <%= f.submit @task.persisted? ? "Update Task" : "Add Task", class: "btn-primary" %>
      <%= link_to "Cancel", @schedule, class: "btn-secondary" %>
    </div>
  <% end %>
</div>

